{
  "info": {
    "name": "Student Records API",
    "_postman_id": "student-records-2024",
    "description": "RESTful API for managing student records - POST Lab Assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" }
  ],
  "item": [
    {
      "name": "GET All Students",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/students",
        "description": "Returns list of all students"
      }
    },
    {
      "name": "GET Student by ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/students/1",
        "description": "Get a specific student by their ID"
      }
    },
    {
      "name": "POST Add New Student",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/students",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Rahul Desai\",\n  \"branch\": \"Computer Science\",\n  \"year\": 2\n}"
        },
        "description": "Add a new student record"
      }
    },
    {
      "name": "PATCH Update Student",
      "request": {
        "method": "PATCH",
        "url": "{{base_url}}/students/1",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aarav Sharma Updated\",\n  \"year\": 3\n}"
        },
        "description": "Update one or more fields of a student"
      }
    },
    {
      "name": "DELETE Student",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/students/1",
        "description": "Delete a student by ID"
      }
    }
  ]
}
